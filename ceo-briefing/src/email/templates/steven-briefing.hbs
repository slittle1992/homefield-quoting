<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pool Care Daily Route — {{date}}</title>
</head>
<body style="margin:0;padding:0;background:#f4f4f7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
<table width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f7;">
<tr><td align="center" style="padding:20px 10px;">
<table width="100%" cellpadding="0" cellspacing="0" style="max-width:600px;background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.08);">

<!-- Header -->
<tr><td style="background:#1e40af;padding:24px 24px;">
  <h1 style="margin:0;color:#ffffff;font-size:20px;font-weight:700;">Good Morning Steven</h1>
  <p style="margin:6px 0 0;color:#93c5fd;font-size:13px;">Second Pool Care — Daily Route for {{date}}</p>
</td></tr>

<!-- Quick Stats -->
<tr><td style="padding:20px 24px 10px;">
  <table width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td width="50%" style="text-align:center;padding:12px;background:#eff6ff;border-radius:8px;">
        <p style="margin:0;font-size:28px;font-weight:700;color:#1e40af;">{{len todayRoutes}}</p>
        <p style="margin:2px 0 0;font-size:11px;color:#6b7280;">Stops Today</p>
      </td>
      <td width="4%"></td>
      <td width="50%" style="text-align:center;padding:12px;background:#eff6ff;border-radius:8px;">
        <p style="margin:0;font-size:28px;font-weight:700;color:{{#if (lt yesterdayCompletion 90)}}#ef4444{{else}}#22c55e{{/if}};">{{percent yesterdayCompletion}}</p>
        <p style="margin:2px 0 0;font-size:11px;color:#6b7280;">Yesterday</p>
      </td>
    </tr>
  </table>
</td></tr>

<!-- Today's Route -->
<tr><td style="padding:16px 24px 10px;">
  <h2 style="margin:0 0 12px;color:#1e40af;font-size:16px;">🗺️ Today's Route</h2>

  {{#if todayRoutes.length}}
  {{#each todayRoutes}}
  <div style="background:#f9fafb;border-radius:8px;padding:14px;margin-bottom:8px;border-left:4px solid #3b82f6;">
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td>
          <p style="margin:0;font-size:14px;font-weight:700;color:#1e40af;">
            <span style="background:#dbeafe;color:#1e40af;padding:2px 8px;border-radius:10px;font-size:11px;margin-right:6px;">{{@index}}</span>
            {{customerName}}
          </p>
          <p style="margin:4px 0 0;font-size:12px;color:#6b7280;">📍 {{address}}</p>
          <p style="margin:2px 0 0;font-size:12px;color:#374151;">{{serviceType}} {{#if scheduledTime}}• {{scheduledTime}}{{/if}}</p>
          {{#if notes}}
          <p style="margin:4px 0 0;font-size:11px;color:#92400e;background:#fefce8;padding:4px 8px;border-radius:4px;display:inline-block;">📝 {{notes}}</p>
          {{/if}}
        </td>
      </tr>
    </table>
  </div>
  {{/each}}
  {{else}}
  <p style="font-size:13px;color:#6b7280;">No stops scheduled for today.</p>
  {{/if}}
</td></tr>

<!-- Customer Notes / Flags -->
{{#if customerAlerts.length}}
<tr><td style="padding:10px 24px;">
  <h2 style="margin:0 0 12px;color:#dc2626;font-size:16px;">⚠️ Customer Alerts</h2>
  {{#each customerAlerts}}
  <div style="background:#fef2f2;border-radius:6px;padding:10px 14px;margin-bottom:6px;">
    <p style="margin:0;font-size:13px;"><strong>{{customerName}}</strong>: {{issue}}</p>
  </div>
  {{/each}}
</td></tr>
{{/if}}

<!-- Invoicing Status -->
{{#if invoicing}}
<tr><td style="padding:10px 24px;">
  <h2 style="margin:0 0 12px;color:#374151;font-size:16px;">💵 Invoicing Status</h2>
  <p style="font-size:13px;margin:4px 0;">This month collected: <strong>{{currency invoicing.thisMonthCollected}}</strong></p>
  <p style="font-size:13px;margin:4px 0;">Last month collected: <strong>{{currency invoicing.lastMonthCollected}}</strong></p>
  {{#if invoicing.pendingPayments}}
  <p style="font-size:13px;margin:4px 0;">Pending: <strong>{{currency invoicing.pendingPayments}}</strong></p>
  {{/if}}
</td></tr>
{{/if}}

<!-- Week Schedule -->
<tr><td style="padding:10px 24px;">
  <h2 style="margin:0 0 12px;color:#374151;font-size:16px;">📅 This Week</h2>
  <table width="100%" cellpadding="6" cellspacing="0" style="font-size:12px;border-collapse:collapse;text-align:center;">
    <tr style="background:#eff6ff;">
      <th style="padding:8px;color:#1e40af;">Mon</th>
      <th style="padding:8px;color:#1e40af;">Tue</th>
      <th style="padding:8px;color:#1e40af;">Wed</th>
      <th style="padding:8px;color:#1e40af;">Thu</th>
      <th style="padding:8px;color:#1e40af;">Fri</th>
      <th style="padding:8px;color:#6b7280;">Sat</th>
      <th style="padding:8px;color:#6b7280;">Sun</th>
    </tr>
    <tr>
      <td style="padding:8px;font-size:18px;font-weight:700;">{{weekSchedule.mon}}</td>
      <td style="padding:8px;font-size:18px;font-weight:700;">{{weekSchedule.tue}}</td>
      <td style="padding:8px;font-size:18px;font-weight:700;">{{weekSchedule.wed}}</td>
      <td style="padding:8px;font-size:18px;font-weight:700;">{{weekSchedule.thu}}</td>
      <td style="padding:8px;font-size:18px;font-weight:700;">{{weekSchedule.fri}}</td>
      <td style="padding:8px;font-size:18px;font-weight:700;color:#9ca3af;">{{weekSchedule.sat}}</td>
      <td style="padding:8px;font-size:18px;font-weight:700;color:#9ca3af;">{{weekSchedule.sun}}</td>
    </tr>
  </table>
</td></tr>

<!-- CEO Notes -->
{{#if ceoNotes}}
<tr><td style="padding:10px 24px;">
  <div style="background:#eff6ff;border-radius:8px;padding:16px;">
    <h3 style="margin:0 0 8px;color:#1e40af;font-size:14px;">📝 Notes from Boss</h3>
    <p style="margin:0;font-size:13px;color:#374151;">{{ceoNotes}}</p>
  </div>
</td></tr>
{{/if}}

<!-- Footer -->
<tr><td style="padding:20px 24px;background:#f9fafb;border-top:1px solid #e5e7eb;">
  <p style="margin:0;font-size:11px;color:#9ca3af;text-align:center;">Second Pool Care — Daily Route | Have a great day! 💪</p>
</td></tr>

</table>
</td></tr>
</table>
</body>
</html>
