<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Homefield Daily Plan — {{date}}</title>
</head>
<body style="margin:0;padding:0;background:#f4f4f7;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">
<table width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f7;">
<tr><td align="center" style="padding:20px 10px;">
<table width="100%" cellpadding="0" cellspacing="0" style="max-width:600px;background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.08);">

<!-- Header -->
<tr><td style="background:#1e4d3a;padding:24px 24px;">
  <h1 style="margin:0;color:#f2eacc;font-size:20px;font-weight:700;">Good Morning Trevor</h1>
  <p style="margin:6px 0 0;color:#a8c5a0;font-size:13px;">Homefield Turf — Daily Plan for {{date}}</p>
</td></tr>

<!-- Today's Schedule -->
<tr><td style="padding:20px 24px 10px;">
  <h2 style="margin:0 0 12px;color:#1e4d3a;font-size:16px;">📋 Today's Schedule</h2>

  {{#if todayAppointments.length}}
  {{#each todayAppointments}}
  <div style="background:#f9fafb;border-radius:8px;padding:14px;margin-bottom:10px;border-left:4px solid #1e4d3a;">
    <p style="margin:0;font-size:15px;font-weight:700;color:#1e4d3a;">{{time}} — {{customerName}}</p>
    <p style="margin:4px 0 0;font-size:12px;color:#6b7280;">📍 {{address}}</p>
    <p style="margin:2px 0 0;font-size:12px;color:#6b7280;">Type: {{type}} {{#if assignedTo}}• Assigned: {{assignedTo}}{{/if}}</p>
  </div>
  {{/each}}
  {{else}}
  <p style="font-size:13px;color:#6b7280;">No appointments scheduled for today.</p>
  {{/if}}
</td></tr>

<!-- Project Plans for Newly Sold Jobs -->
{{#if projectPlans.length}}
<tr><td style="padding:10px 24px;">
  <h2 style="margin:0 0 12px;color:#1e4d3a;font-size:16px;">🏗️ New Project Plans</h2>

  {{#each projectPlans}}
  <div style="background:#f0fdf4;border-radius:8px;padding:16px;margin-bottom:16px;border:1px solid #bbf7d0;">
    <h3 style="margin:0 0 8px;color:#166534;font-size:15px;">{{customerName}}</h3>
    <p style="margin:0 0 4px;font-size:12px;">📍 {{address}}</p>
    <p style="margin:0 0 4px;font-size:12px;">📅 Install: {{installDate}} | ⏱️ Est. time: {{estimatedTime}}</p>
    <p style="margin:0 0 12px;font-size:12px;">🚚 Materials delivery: {{deliveryDate}}</p>

    <h4 style="margin:0 0 6px;color:#374151;font-size:13px;">Materials Needed:</h4>
    <ul style="margin:0 0 12px;padding-left:20px;font-size:12px;">
      {{#each materialsNeeded}}
      <li style="margin:3px 0;">{{this}}</li>
      {{/each}}
    </ul>

    <h4 style="margin:0 0 6px;color:#374151;font-size:13px;">Site Prep:</h4>
    <ul style="margin:0 0 12px;padding-left:20px;font-size:12px;">
      {{#each sitePrep}}
      <li style="margin:3px 0;">{{this}}</li>
      {{/each}}
    </ul>

    <h4 style="margin:0 0 6px;color:#374151;font-size:13px;">Install Steps:</h4>
    <ol style="margin:0 0 12px;padding-left:20px;font-size:12px;">
      {{#each installSteps}}
      <li style="margin:3px 0;">{{this}}</li>
      {{/each}}
    </ol>

    {{#if specialNotes.length}}
    <div style="background:#fefce8;border-radius:6px;padding:10px;margin-top:8px;">
      <p style="margin:0 0 4px;font-size:11px;font-weight:700;color:#92400e;">⚠️ NOTES:</p>
      {{#each specialNotes}}
      <p style="margin:2px 0;font-size:11px;color:#92400e;">• {{this}}</p>
      {{/each}}
    </div>
    {{/if}}
  </div>
  {{/each}}
</td></tr>
{{/if}}

<!-- Production Pipeline -->
{{#if productionPipeline.length}}
<tr><td style="padding:10px 24px;">
  <h2 style="margin:0 0 12px;color:#1e4d3a;font-size:16px;">🔧 This Week's Pipeline</h2>
  <table width="100%" cellpadding="6" cellspacing="0" style="font-size:12px;border-collapse:collapse;">
    {{#each productionPipeline}}
    <tr style="border-bottom:1px solid #f3f4f6;">
      <td style="padding:8px;">{{customerName}}</td>
      <td style="padding:8px;"><span style="background:#dbeafe;color:#1e40af;padding:2px 8px;border-radius:10px;font-size:10px;">{{status}}</span></td>
      <td style="padding:8px;color:#6b7280;">{{shortDate scheduledDate}}</td>
    </tr>
    {{/each}}
  </table>
</td></tr>
{{/if}}

<!-- CEO Notes -->
{{#if ceoNotes}}
<tr><td style="padding:10px 24px;">
  <div style="background:#eff6ff;border-radius:8px;padding:16px;">
    <h3 style="margin:0 0 8px;color:#1e40af;font-size:14px;">📝 Notes from Boss</h3>
    <p style="margin:0;font-size:13px;color:#374151;">{{ceoNotes}}</p>
  </div>
</td></tr>
{{/if}}

<!-- Footer -->
<tr><td style="padding:20px 24px;background:#f9fafb;border-top:1px solid #e5e7eb;">
  <p style="margin:0;font-size:11px;color:#9ca3af;text-align:center;">Homefield Turf — Daily Plan | Have a great day! 💪</p>
</td></tr>

</table>
</td></tr>
</table>
</body>
</html>
