DATABASE_URL=postgresql://user:password@localhost:5432/pooldrop
JWT_SECRET=your-secret-key-change-this
PORT=3001
NODE_ENV=development

# Mapbox for reverse geocoding
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# Daily drop generation limit
DAILY_DROP_LIMIT=50

# Mailer feature flag
MAILER_ENABLED=false

# Mailer provider config (e.g., Lob)
MAILER_API_KEY=
MAILER_API_BASE_URL=

# Lob direct mail
LOB_API_KEY=

# Company info (used for mailer sender address and templates)
COMPANY_NAME=
COMPANY_ADDRESS=
COMPANY_CITY=
COMPANY_STATE=TX
COMPANY_ZIP=
COMPANY_PHONE=
COMPANY_WEBSITE=
COMPANY_LOGO_URL=

# GoHighLevel CRM
GHL_API_KEY=
GHL_LOCATION_ID=

# Meta Ads
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=

# Permit scraper
PERMIT_SCRAPE_ENABLED=false
PERMIT_SCRAPE_CRON=0 6 * * *
PERMIT_COUNTIES=williamson

# CORS origin
CORS_ORIGIN=http://localhost:3000
