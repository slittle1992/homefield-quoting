DATABASE_URL=postgresql://user:password@localhost:5432/pooldrop
JWT_SECRET=your-secret-key-change-this
PORT=3001
NODE_ENV=development

# Mapbox for reverse geocoding
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# Daily drop generation limit
DAILY_DROP_LIMIT=50

# Mailer feature flag
MAILER_ENABLED=false

# Mailer provider config (e.g., Lob)
MAILER_API_KEY=
MAILER_API_BASE_URL=

# CORS origin
CORS_ORIGIN=http://localhost:3000
